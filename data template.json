{
    "$List ID$": {
        "listTitle": "$listTitle$",
        "entries" : {
            "$Entry ID$": {
                "entryTitle": "$entryTitle$",
                "status": "$status$",
                "rewatched": "$count",
                "totalEpisodes": {
                    "total": "$count$",
                    "episodes": "$count$",
                    "movies": "$count$",
                    "special": "$count$"
                },
                "progress": {
                    "total": "$count$",
                    "episodes": "$count$",
                    "movies": "$count$",
                    "special": "$count$"
                },
                "seasons": {
                    "$Season ID$": {
                        "seasonTitle": "$seasonTitle$",
                        "site": "$site$",
                        "rating": "$rating$",
                        "episodes": {
                            "$EP ID$": {
                                "text": "$text$",
                                "completed": "$completedState$",
