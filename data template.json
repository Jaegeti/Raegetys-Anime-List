{
    "$List ID$": {
        "listTitle": "$listTitle$",
        "$Entry ID$": {
            "mainTitle": "$mainTitle$",
            "status": "$status$",
            "rewatched": "$count",
            "totalEpisodes": {
                "total": "$count$",
                "episodes": "$count$",
                "movies": "$count$",
                "special": "$count$"
            },
            "progress": {
                "total": "$count$",
                "episodes": "$count$",
                "movies": "$count$",
                "special": "$count$"
            },
            "seasons": {
